#!/bin/bash

# Check script for validating ODCS and ODPS templates
#
# Prerequisites:
#   - datacontract-cli: pip install datacontract-cli
#   - ajv-cli: npm install -g ajv-cli
#   - ajv-formats: npm install -g ajv-formats
#   - yq: brew install yq (macOS) or see https://github.com/mikefarah/yq
#
# Usage:
#   ./scripts/check

set -e

echo "Checking ODCS files..."
for file in $(find . -name "*.odcs.yaml" -type f); do
  echo ""
  echo "  Checking $file with datacontract lint..."
  datacontract lint "$file"
  echo "  Validating $file with ajv..."
  ajv validate --spec=draft2019 --all-errors -c ajv-formats -s odcs/jsonschema/odcs-json-schema-v3.0.2.json -d "$file"
done

echo ""
echo "Checking ODPS files with ajv..."
for file in $(find . -name "*.odps.yaml" -type f); do
  echo "  Validating $file..."
  ajv validate --spec=draft2019 --all-errors -c ajv-formats -s odps/jsonschema/odps-json-schema-v1.0.0.json -d "$file"
done

echo ""
echo "All checks passed!"
